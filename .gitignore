# ─── Terraform / Terragrunt ───────────────────────────────────────────────────
.terraform/
.terragrunt-cache/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log

# Generated by terragrunt at init time (remote_state + provider blocks in root.hcl)
backend.tf
provider.tf

# Ignore auto-generated override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Local terraform CLI configs
.terraformrc
terraform.rc

# ─── Go ───────────────────────────────────────────────────────────────────────
# Compiled binaries (e.g. `go build` output in proxy/)
proxy/proxy
*.exe
*.dll
*.so
*.dylib
*.test
*.out

# Go workspace files
go.work
go.work.sum

# ─── IDEs ─────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.ipr
*.iws

# ─── Local Claude Code state ──────────────────────────────────────────────────
.claude/

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Env / secrets ────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
